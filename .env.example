# Public Supabase browser config.
# The anon key is safe to expose only when Row Level Security policies are correct.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-public-anon-key

# Server-only AI keys. Configure them in Vercel, never in frontend code.
# Fallback order: Groq -> Cerebras -> OpenRouter -> Gemini (all optional
# except at least one).
GROQ_API_KEY=your-groq-api-key
# Free fallback with generous limits: https://cloud.cerebras.ai (API Keys)
CEREBRAS_API_KEY=
# Aggregator with free model variants: https://openrouter.ai/keys
OPENROUTER_API_KEY=
# Google fallback: https://aistudio.google.com/apikey
GEMINI_API_KEY=
