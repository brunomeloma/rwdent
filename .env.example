# Public Supabase browser config.
# The anon key is safe to expose only when Row Level Security policies are correct.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-public-anon-key

# Server-only AI keys. Configure them in Vercel, never in frontend code.
GROQ_API_KEY=your-groq-api-key
# Optional free fallback used when Groq hits its rate limit.
# Create a free key at https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key
