# Public Supabase browser config.
# The anon key is safe to expose only when Row Level Security policies are correct.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-public-anon-key

# Server-only AI key. Configure it in Vercel, never in frontend code.
GROQ_API_KEY=your-groq-api-key
